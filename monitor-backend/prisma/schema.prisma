generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PingRecord {
  id           String   @id @default(uuid())
  url          String
  method       String   @default("POST")
  payload      Json
  statusCode   Int?
  responseBody Json?
  responseTime Int
  success      Boolean  @default(true)
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([success])
}
